TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_PrefabParentObject: {fileID: 0}
  m_PrefabInternal: {fileID: 0}
  m_GameObject: {fileID: 43}
  m_Text: "Here is the first killing field! You have 5 minutes to kill all of the critters. Yes, yes,\r\nI know what you are thinking: your battery only lasts 5 minutes. I swear I'm working day and\r\nnight to make it better. Hey, don't look at me like that! Stop wasting time and get started!"
  m_OffsetZ: 0
  m_CharacterSize: 1
  m_LineSpacing: 1
  m_Anchor: 3
  m_Alignment: 0
  m_TabSize: 4
  m_FontSize: 32
  m_FontStyle: 0
